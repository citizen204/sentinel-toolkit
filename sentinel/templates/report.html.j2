<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Sentinel Report</title>
  <style>
    body { font-family: system-ui, sans-serif; margin: 2rem; color: #1a1a1a; }
    h1 { margin-bottom: 0.25rem; }
    .meta { color: #666; font-size: 0.9rem; margin-bottom: 1.5rem; }
    .summary span { display: inline-block; padding: 0.25rem 0.6rem; margin-right: 0.4rem;
                    border-radius: 4px; font-size: 0.85rem; }
    .Critical { background: #7f1d1d; color: #fff; }
    .High { background: #b91c1c; color: #fff; }
    .Medium { background: #d97706; color: #fff; }
    .Low { background: #ca8a04; color: #fff; }
    .Info { background: #2563eb; color: #fff; }
    .finding { border-left: 4px solid #ccc; padding: 0.5rem 1rem; margin: 0.75rem 0;
               background: #fafafa; }
    .finding.Critical { border-color: #7f1d1d; }
    .finding.High { border-color: #b91c1c; }
    .finding.Medium { border-color: #d97706; }
    .finding.Low { border-color: #ca8a04; }
    .finding.Info { border-color: #2563eb; }
    .rem { color: #065f46; font-size: 0.9rem; }
    .cat { display: inline-block; margin-left: 0.4rem; padding: 0.05rem 0.45rem;
           border-radius: 999px; background: #e2e8f0; color: #334155; font-size: 0.75rem; }
    .refs { font-size: 0.8rem; color: #64748b; }
    .refs a { color: #2563eb; }
    .supp { display: inline-block; margin-left: 0.4rem; padding: 0.05rem 0.45rem;
            border-radius: 999px; background: #cbd5e1; color: #334155; font-size: 0.75rem; }
    .finding.suppressed { opacity: 0.55; }
    code { background: #eee; padding: 0 0.2rem; }
  </style>
</head>
<body>
  <h1>Sentinel Security Report</h1>
  <div class="meta">Generated at {{ generated_at }}</div>
  <div class="summary">
    {% for sev, count in summary.items() %}
      <span class="{{ sev }}">{{ sev }}: {{ count }}</span>
    {% endfor %}
    {% if suppressed %}<span class="supp">Suppressed: {{ suppressed }}</span>{% endif %}
  </div>
  {% for f in findings %}
    <div class="finding {{ f.severity.value }}{% if f.status.value == 'suppressed' %} suppressed{% endif %}">
      <strong>[{{ f.severity.value }}] {{ f.title }}</strong>
      <span style="color:#888">({{ f.module }} — {{ f.id }})</span>
      {% if f.status.value == 'suppressed' %}<span class="supp">suppressed{% if f.suppression_reason %}: {{ f.suppression_reason }}{% endif %}</span>{% endif %}
      {% if f.category %}<span class="cat">{{ f.category }}</span>{% endif %}
      {% if f.confidence %}<span class="cat">confidence: {{ f.confidence.value }}</span>{% endif %}
      <p>{{ f.description }}</p>
      {% if f.asset %}
        <p>Asset: <code>{{ f.asset.type }}:{{ f.asset.id }}</code>
          {% if f.asset.region %}<span class="refs">({{ f.asset.provider }} · {{ f.asset.region }})</span>{% endif %}
        </p>
      {% elif f.resource %}<p>Resource: <code>{{ f.resource }}</code></p>{% endif %}
      <p class="rem">Fix: {{ f.remediation }}</p>
      {% if f.references %}
        <p class="refs">References:
          {% for ref in f.references %}<a href="{{ ref }}">{{ ref }}</a>{% if not loop.last %}, {% endif %}{% endfor %}
        </p>
      {% endif %}
    </div>
  {% endfor %}
</body>
</html>
